@{ ViewData["Title"] = "Thống Kê Báo Cáo"; }

<div class="d-flex justify-content-between align-items-center mb-5 mt-4">
    <h2 class="text-primary fw-bold">📊 Thống Kê & Báo Cáo Hệ Thống</h2>
    <button class="btn btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer"></i> In Báo Cáo</button>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-primary shadow-sm h-100 border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Tổng Đầu Sách</h6>
                        <h2 class="mb-0 fw-bold display-5">@ViewBag.TotalTitles</h2>
                    </div>
                    <i class="bi bi-book" style="font-size: 3.5rem; opacity: 0.5;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card text-white bg-success shadow-sm h-100 border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Số Sinh Viên</h6>
                        <h2 class="mb-0 fw-bold display-5">@ViewBag.TotalUsers</h2>
                    </div>
                    <i class="bi bi-people" style="font-size: 3.5rem; opacity: 0.5;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card text-dark bg-warning shadow-sm h-100 border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Đang Cho Mượn</h6>
                        <h2 class="mb-0 fw-bold display-5">@ViewBag.TotalBorrowing</h2>
                    </div>
                    <i class="bi bi-journal-arrow-up" style="font-size: 3.5rem; opacity: 0.5;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4">
        <div class="card text-white bg-info shadow-sm h-100 border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Lượt Trả Sách</h6>
                        <h2 class="mb-0 fw-bold display-5 text-white">@ViewBag.TotalReturned</h2>
                    </div>
                    <i class="bi bi-journal-check text-white" style="font-size: 3.5rem; opacity: 0.5;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="alert alert-light border shadow-sm text-center p-4 rounded-4">
            <i class="bi bi-graph-up text-success mb-3" style="font-size: 3rem;"></i>
            <h5 class="fw-bold">Hệ thống thư viện hoạt động ổn định!</h5>
            <p class="text-muted mb-0">Mọi dữ liệu mượn trả và thông tin sách đã được đồng bộ với CSDL và hệ thống đèn LED định vị IoT.</p>
        </div>
    </div>
    <div class="row mt-4 mb-5">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-danger text-white fw-bold py-3">
                <i class="bi bi-exclamation-triangle-fill"></i> Danh Sách Độc Giả Mượn Quá Hạn
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Người Mượn</th>
                                <th>Sách Mượn</th>
                                <th>Ngày Mượn</th>
                                <th>Hạn Trả</th>
                                <th>Tình Trạng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.OverdueRecords != null && ViewBag.OverdueRecords.Count > 0)
                            {
                                foreach (var item in ViewBag.OverdueRecords)
                                {
                                    // Tính số ngày quá hạn
                                    var overdueDays = (DateTime.Now - item.DueDate).Days;
                                    <tr>
                                        <td class="fw-bold">@(item.Student?.FullName ?? "N/A")</td>
                                        <td class="text-primary fw-bold">@(item.Book?.Title ?? "N/A")</td>
                                        <td>@item.BorrowDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-danger fw-bold">@item.DueDate.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge bg-danger rounded-pill px-3 py-2">Quá hạn @overdueDays ngày</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <i class="bi bi-emoji-smile text-success" style="font-size: 2rem;"></i>
                                        <p class="mt-2 mb-0">Tuyệt vời! Hiện tại không có độc giả nào mượn sách quá hạn.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
</div>