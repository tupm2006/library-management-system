@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.BorrowRecord>
@{ ViewData["Title"] = "Duyệt Gia Hạn Sách"; }

<div class="mt-4 mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-calendar-plus-fill"></i> Quản Lý Yêu Cầu Gia Hạn</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm fw-bold">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Sinh Viên</th>
                    <th>Tên Sách</th>
                    <th>Ngày Hẹn Trả (Cũ)</th>
                    <th>Trạng Thái</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@(item.Student?.FullName ?? "N/A")</td>
                        <td class="text-primary fw-bold">@(item.Book?.Title ?? "N/A")</td>
                        <td class="text-danger fw-bold">@item.DueDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.ExtensionStatus == "Pending") { <span class="badge bg-warning text-dark">Chờ duyệt</span> }
                            else if (item.ExtensionStatus == "Approved") { <span class="badge bg-success">Đã duyệt (+7 ngày)</span> }
                            else { <span class="badge bg-danger">Đã từ chối</span> }
                        </td>
                        <td class="text-center">
                            @if (item.ExtensionStatus == "Pending")
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <form asp-action="Approve" method="post" class="m-0">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success fw-bold"><i class="bi bi-check"></i> Duyệt</button>
                                    </form>
                                    <form asp-action="Reject" method="post" class="m-0">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold"><i class="bi bi-x"></i> Từ chối</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>