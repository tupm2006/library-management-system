@model SmartLibraryManagementSystem.Data.Entities.Book
@{ ViewData["Title"] = "Xóa Sách"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="alert alert-danger shadow-sm">
            <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo!</h4>
            <p>Bạn có chắc chắn muốn xóa cuốn sách <strong>@Model.Title</strong> khỏi hệ thống không? Hành động này không thể hoàn tác!</p>
            <hr>
            <div class="mb-3">
                <strong>Mã sách:</strong> @Model.BookCode <br />
                <strong>Tác giả:</strong> @Model.Author <br />
                <strong>Thể loại:</strong> @Model.Category
            </div>
            
            <form asp-action="Delete" method="post" class="d-flex justify-content-between">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-light border">Hủy, quay lại</a>
                <button type="submit" class="btn btn-danger fw-bold">Đúng, Xóa ngay!</button>
            </form>
        </div>
    </div>
</div>