@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.BorrowRecord>
@{ ViewData["Title"] = "Tủ Sách Của Tôi"; }

<div class="mt-4 mb-5">
    <div class="d-flex align-items-center mb-2">
        <div class="bg-primary-container text-primary p-3 rounded-pill me-3 shadow-sm align-items-center d-flex justify-content-center" style="width: 54px; height: 54px;">
            <i class="bi bi-person-lines-fill fs-4"></i>
        </div>
        <h1 class="fw-bold text-primary mb-0">Tủ Sách Cá Nhân</h1>
    </div>
    <p class="text-muted ms-1 fs-5">Quản lý sách đang chờ lấy và lịch sử đọc của bạn.</p>
</div>

<!-- Sách Đang Đặt Trước -->
<div class="card shadow-sm border-0 mb-5 overflow-hidden" style="border-radius: 28px !important;">
    <div class="card-header bg-tertiary-container text-tertiary fw-bold py-4 px-4 fs-5 border-0">
        <i class="bi bi-clock-history me-2"></i> Chờ Lấy Tại Kiosk (Hẹn 24h)
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-surface-variant text-on-surface-variant small text-uppercase fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Tên Sách</th>
                        <th>Vị trí Kiosk</th>
                        <th>Thời gian đặt</th>
                        <th class="pe-4">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (ViewBag.MyReservations != null && ViewBag.MyReservations.Count > 0)
                    {
                        foreach (var res in ViewBag.MyReservations)
                        {
                            var expireTime = res.ReservationDate.AddHours(24);
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary fs-6">@(res.Book?.Title ?? "N/A")</div>
                                    <small class="text-muted">Mã: @(res.Book?.BookCode ?? "N/A")</small>
                                </td>
                                <td><span class="badge btn-tonal px-3 py-2">Kệ: @(res.Book?.ShelfCode ?? "N/A")</span></td>
                                <td class="small">@res.ReservationDate.ToString("HH:mm - dd/MM/yyyy")</td>
                                <td class="pe-4">
                                    <div class="d-flex flex-column align-items-start">
                                        <span class="badge bg-warning text-dark px-3 rounded-pill"><i class="bi bi-lightning-charge-fill me-1"></i> Sẵn sàng</span>
                                        <small class="text-danger mt-1 opacity-75" style="font-size: 11px;">Hủy lúc: @expireTime.ToString("HH:mm - dd/MM")</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-5 fs-6">Bạn không có đơn đặt trước nào hiện tại.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Lịch Sử Mượn Trả -->
<div class="card shadow-sm border-0 overflow-hidden" style="border-radius: 28px !important;">
    <div class="card-header bg-primary-container text-primary fw-bold py-4 px-4 fs-5 border-0">
        <i class="bi bi-journal-check me-2"></i> Tiến Độ Đọc & Lịch Sử
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-surface-variant text-on-surface-variant small text-uppercase fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Sách Đã Mượn</th>
                        <th>Ngày Mượn</th>
                        <th>Hạn Trả</th>
                        <th class="pe-4">Tình Trạng</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">@(item.Book?.Title ?? "N/A")</div>
                                    <small class="text-muted">@item.Book?.Author</small>
                                </td>
                                <td class="small">@item.BorrowDate.ToString("dd/MM/yyyy")</td>
                                <td class="small">@item.DueDate.ToString("dd/MM/yyyy")</td>
                                <td class="pe-4">
                                    @if(item.Status == "Borrowing") {
                                        var isOverdue = item.DueDate < DateTime.Now;
                                        <span class="badge @(isOverdue ? "bg-danger" : "bg-primary") px-3 rounded-pill mb-1">
                                            @(isOverdue ? "Quá hạn" : "Đang mượn")
                                        </span>
                                        <br/>
                                        @if(string.IsNullOrEmpty(item.ExtensionStatus)) {
                                            <form asp-action="RequestExtension" method="post" class="mt-1">
                                                <input type="hidden" name="borrowId" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-tonal py-1" style="font-size: 0.7rem;"><i class="bi bi-calendar-plus me-1"></i> Xin gia hạn</button>
                                            </form>
                                        } else {
                                            <span class="badge btn-tonal mt-1" style="font-size: 10px;">
                                                <i class="bi bi-info-circle me-1"></i> @(item.ExtensionStatus == "Pending" ? "Đang chờ duyệt" : "Đã xử lý")
                                            </span>
                                        }
                                    } else {
                                        <div class="d-flex align-items-center">
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 rounded-pill">
                                                <i class="bi bi-check2-all me-1"></i> Đã trả
                                            </span>
                                            <a href="/Home/BookDetails/@item.BookId" class="btn btn-link btn-sm text-warning ms-2 p-0" title="Đánh giá">
                                                <i class="bi bi-star-fill"></i>
                                            </a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-5 fs-6">Hành trình tri thức của bạn chưa bắt đầu. Mượn sách ngay!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>