@model SmartLibraryManagementSystem.Data.Entities.Book
@{ ViewData["Title"] = Model.Title; }

<div class="row mt-4 mb-5">
    <div class="col-md-4 mb-4">
        <div class="card shadow-lg sticky-top" style="top: 100px;">
            <img src="https://picsum.photos/seed/@Model.BookCode/400/600" class="card-img-top" alt="Cover">
            <div class="card-body p-4">
                <h3 class="fw-bold text-primary mb-3">@Model.Title</h3>
                <p class="text-muted mb-4 small"><i class="bi bi-person-fill"></i> Tác giả: @Model.Author</p>
                
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="m3-badge bg-tertiary-container text-on-tertiary-container mb-0" style="font-size: 0.75rem;">@Model.Category</span>
                    <span class="m3-badge bg-primary-container text-primary mb-0" style="font-size: 0.75rem;">Kệ: @Model.ShelfCode</span>
                </div>

                <div class="p-3 bg-surface-container-low rounded-4 mb-4 border border-surface-variant">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small fw-bold text-muted">Trạng thái:</span>
                        <span class="badge @(Model.AvailableQuantity > 0 ? "bg-success" : "bg-danger") rounded-pill">@(Model.AvailableQuantity > 0 ? "Còn sách" : "Hết sách")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small fw-bold text-muted">Số lượng khả dụng:</span>
                        <span class="fw-bold">@Model.AvailableQuantity quyển</span>
                    </div>
                </div>
                
                <div class="d-grid gap-2">
                    @if (User.IsInRole("Student"))
                    {
                        <form asp-controller="Home" asp-action="ReserveBook" method="post" class="m-0">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">
                                <i class="bi bi-bookmark-plus-fill me-2"></i> Đăng ký mượn ngay
                            </button>
                        </form>
                    }
                    <button class="btn btn-tonal w-100 py-3 fw-bold btn-locate" data-shelf="@Model.ShelfCode">
                        <i class="bi bi-geo-alt-fill me-2"></i> Tìm trên kệ (IoT)
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h4 class="fw-bold d-flex align-items-center">
                    <div class="p-2 bg-primary bg-opacity-10 rounded-pill me-3" style="width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-chat-left-text-fill text-primary"></i>
                    </div>
                    Đánh giá & Thảo luận
                </h4>
            </div>
            <div class="card-body p-4">
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-action="PostComment" method="post" class="bg-surface p-4 rounded-4 mb-5 border border-surface-variant">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        
                        @if (ViewBag.HasBorrowed)
                        {
                            <div class="alert alert-success border-0 rounded-4 mb-4 py-3 d-flex align-items-center">
                                <i class="bi bi-patch-check-fill fs-4 me-3"></i>
                                <span>Bạn đã mượn cuốn sách này. Hãy để lại đánh giá nhé!</span>
                            </div>
                            <div class="mb-4 d-flex align-items-center">
                                <label class="fw-bold me-4">Chất lượng:</label>
                                <div class="rating-stars text-warning fs-3" style="cursor: pointer;">
                                    <i class="bi bi-star-fill star-select" data-val="1"></i>
                                    <i class="bi bi-star-fill star-select" data-val="2"></i>
                                    <i class="bi bi-star-fill star-select" data-val="3"></i>
                                    <i class="bi bi-star-fill star-select" data-val="4"></i>
                                    <i class="bi bi-star-fill star-select" data-val="5"></i>
                                </div>
                                <input type="hidden" name="rating" id="ratingInput" value="5" />
                            </div>
                        }

                        <div class="form-floating mb-3">
                            <textarea name="commentText" id="commentBox" class="form-control rounded-4 border-surface-variant" style="height: 120px" placeholder="Viết bình luận..." required></textarea>
                            <label for="commentBox">Viết bình luận...</label>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-5 fw-bold">
                                Gửi đi <i class="bi bi-send-fill ms-2"></i>
                            </button>
                        </div>
                    </form>
                }

                <div class="comment-list">
                    <h6 class="fw-bold text-muted mb-4 opacity-75">Tất cả bình luận (@(ViewBag.Reviews?.Count ?? 0))</h6>
                    
                    @if (ViewBag.Reviews != null && ViewBag.Reviews.Count > 0)
                    {
                        foreach (var review in ViewBag.Reviews)
                        {
                            string rName = review.Student?.FullName ?? "Người dùng ẩn danh";

                            <div class="d-flex mb-4 p-3 rounded-4 hover-surface transition-all">
                                <div class="flex-shrink-0">
                                    <div class="bg-primary-container text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 48px; height: 48px;">
                                        @rName.Substring(0, 1).ToUpper()
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="bg-surface-container p-3 rounded-4" style="border-radius: 0 24px 24px 24px !important;">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="fw-bold mb-0 text-primary">@rName</h6>
                                            <small class="text-muted opacity-50">vừa xong</small>
                                        </div>
                                        <p class="mb-0 text-on-surface">@review.Comment</p>
                                    </div>
                                    <div class="mt-2 ms-2">
                                        <button class="btn btn-link btn-sm text-decoration-none text-muted fw-bold btn-reply p-0 opacity-75" data-name="@rName">
                                            <i class="bi bi-reply-fill"></i> Trả lời
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-chat-dots fs-1 mb-3 opacity-25"></i>
                            <p>Chưa có thảo luận nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btn-reply').click(function () {
                var name = $(this).data('name');
                var box = $('#commentBox');
                box.val('@@' + name + ': ' + box.val()).focus();
            });

            $('.star-select').click(function () {
                var val = $(this).data('val');
                $('#ratingInput').val(val);
                $('.star-select').removeClass('text-warning text-muted').addClass('text-muted');
                $(this).prevAll().addBack().removeClass('text-muted').addClass('text-warning');
            });
        });
    </script>
}