@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.User>
@{ ViewData["Title"] = "Quản lý Người Dùng"; }

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="text-primary fw-bold">👥 Quản lý Người Dùng</h2>
    <a asp-action="Create" class="btn btn-success fw-bold"><i class="bi bi-person-plus-fill"></i> Thêm User Mới</a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-bordered table-hover bg-white mb-0">
        <thead class="table-dark">
            <tr>
                <th>Họ Tên</th>
                <th>Tài Khoản</th>
                <th>Vai Trò</th>
                <th>Lớp Học</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="fw-bold">@item.FullName</td>
                    <td class="text-success fw-bold">@item.Username</td>
                    <td><span class="badge @(item.Role == "Librarian" ? "bg-danger" : "bg-primary")">@item.Role</span></td>
                    <td>@item.StudentClass</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil-square"></i> Sửa</a>
                        @if(item.Username != "admin") {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>