@model SmartLibraryManagementSystem.Data.Entities.Book
@{ ViewData["Title"] = "Thêm Sách Mới"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-plus-circle"></i> Thêm Sách Mới
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mã Sách</label>
                            <input asp-for="BookCode" class="form-control" placeholder="VD: IT-003" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Vị Trí Giá Sách (Mã IoT)</label>
                            <input asp-for="ShelfCode" class="form-control" placeholder="VD: A1-R1" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên Sách</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tác Giả</label>
                        <input asp-for="Author" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Thể Loại</label>
                            <input asp-for="Category" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số Lượng</label>
                            <input asp-for="AvailableQuantity" class="form-control" type="number" min="0" value="1" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-success fw-bold">Lưu Sách</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>