@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.Book>
@{ ViewData["Title"] = "Sách Nổi Bật"; }

<div class="mt-4 mb-5">
    <div class="d-flex align-items-center mb-2">
        <div class="bg-tertiary-container text-tertiary p-3 rounded-pill me-3 shadow-sm align-items-center d-flex justify-content-center" style="width: 54px; height: 54px;">
            <i class="bi bi-fire fs-4"></i>
        </div>
        <h1 class="fw-bold text-primary mb-0">Bảng Xếp Hạng Thịnh Hành</h1>
    </div>
    <p class="text-muted ms-1 fs-5">Những cuốn sách được mượn nhiều nhất trong hệ thống.</p>
</div>

<div class="card shadow-sm mb-5" style="border-radius: 24px !important; background: var(--m3-surface-container-low);">
    <div class="card-body p-4 d-flex flex-wrap align-items-center gap-3">
        <span class="fw-bold opacity-75"><i class="bi bi-funnel-fill me-2"></i>Lọc theo:</span>
        <div class="d-flex gap-2">
            <a href="?filter=week" class="btn @(ViewBag.CurrentFilter == "week" ? "btn-primary" : "btn-tonal") px-4 shadow-none">Tuần này</a>
            <a href="?filter=month" class="btn @(ViewBag.CurrentFilter == "month" ? "btn-primary" : "btn-tonal") px-4">Tháng này</a>
            <a href="?filter=year" class="btn @(ViewBag.CurrentFilter == "year" ? "btn-primary" : "btn-tonal") px-4">Cả năm</a>
        </div>

        <div class="ms-md-auto">
            <select class="form-select border-surface-variant rounded-pill px-4 py-2 bg-white" style="cursor: pointer;">
                <option>Lượt mượn nhiều nhất</option>
                <option>Đánh giá cao nhất</option>
                <option>Mới nhất</option>
            </select>
        </div>
    </div>
</div>

<div class="row g-4" id="book-list">
    @{ int rank = 1; }
    @foreach (var book in Model)
    {
        <div class="col-12 mb-2">
            <div class="card hover-surface transition-all book-item" style="border-radius: 28px !important;">
                <div class="card-body p-4 d-flex align-items-center">
                    <h1 class="text-primary fw-bold me-4 ms-2 display-3 opacity-25" style="min-width: 80px;">#@rank</h1>
                    
                    <div class="position-relative">
                        <img src="https://picsum.photos/seed/@book.BookCode/150/200" class="rounded-4 shadow-sm" style="width: 90px; height: 130px; object-fit: cover;" />
                    </div>
                    
                    <div class="ms-4 flex-grow-1">
                        <h4 class="fw-bold text-primary mb-1">@book.Title</h4>
                        <p class="text-muted mb-2 d-flex align-items-center">
                            <i class="bi bi-person-fill-check me-2"></i> @book.Author 
                            <span class="mx-3 opacity-25">|</span>
                            <span class="badge btn-tonal" style="border-radius: 100px; font-size: 11px;">@book.Category</span>
                        </p>
                        <div class="text-warning d-flex align-items-center" style="font-size: 0.9rem;">
                            <i class="bi bi-star-fill me-1"></i>
                            <i class="bi bi-star-fill me-1"></i>
                            <i class="bi bi-star-fill me-1"></i>
                            <i class="bi bi-star-fill me-1"></i>
                            <i class="bi bi-star-half me-2"></i>
                            <span class="text-muted small">(@(1500 - rank * 45) đánh giá)</span>
                        </div>
                    </div>

                    <div class="text-end ms-3">
                        <div class="mb-2">
                            <span class="badge bg-tertiary-container text-tertiary fs-5 py-2 px-3 rounded-4">
                                <i class="bi bi-graph-up-arrow me-2 font-bold"></i>@(200 - rank * 15)
                            </span>
                        </div>
                        <a href="/Home/BookDetails/@book.Id" class="btn btn-tonal rounded-pill fw-bold">
                            Chi tiết <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        rank++;
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-tonal, .btn-primary').not('[href]').click(function(e) {
                // Visual feedback for filter change
                $('#book-list').animate({ opacity: 0.4 }, 200, function() {
                    setTimeout(() => $('#book-list').animate({ opacity: 1 }, 200), 300);
                });
            });
        });
    </script>
}