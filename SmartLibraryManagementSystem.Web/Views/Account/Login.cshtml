@{ ViewData["Title"] = "Đăng nhập"; }

<div class="row justify-content-center align-items-center mb-5" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg p-3" style="border-radius: 36px !important;">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-flex bg-primary bg-opacity-10 p-4 rounded-circle mb-3">
                        <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                    </div>
                    <h2 class="fw-bold text-primary">Đăng Nhập</h2>
                    <p class="text-muted small">Mời bạn đăng nhập để tiếp tục</p>
                </div>

                @if (ViewBag.Error != null) { 
                    <div class="alert btn-tonal border-0 text-center mb-4" style="border-radius: 16px; color: var(--m3-on-tertiary-container); background: var(--m3-tertiary-container);">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    </div> 
                }

                <form method="post" action="/Account/Login">
                    <div class="form-floating mb-3">
                        <input type="text" name="username" class="form-control rounded-4 border-surface-variant bg-white" id="userInp" value="admin" placeholder="Tài khoản" required />
                        <label for="userInp">Tên đăng nhập</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="password" name="password" class="form-control rounded-4 border-surface-variant bg-white" id="passInp" value="123456" placeholder="Mật khẩu" required />
                        <label for="passInp">Mật khẩu</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm">
                        ĐĂNG NHẬP <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>

                <div class="text-center mt-4 pt-2">
                    <p class="small text-muted mb-0">Chưa có tài khoản? Liên hệ thủ thư.</p>
                </div>
            </div>
        </div>
    </div>
</div>