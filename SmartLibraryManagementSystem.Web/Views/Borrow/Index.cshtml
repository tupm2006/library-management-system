@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.BorrowRecord>
@{ ViewData["Title"] = "Quản lý Mượn Trả"; }

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="text-primary fw-bold">🔄 Quản lý Lịch sử Mượn / Trả</h2>
    <a asp-action="Create" class="btn btn-success fw-bold"><i class="bi bi-journal-plus"></i> Lập Phiếu Mượn Sách</a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-bordered table-hover bg-white mb-0">
        <thead class="table-dark">
            <tr>
                <th>Người Mượn</th>
                <th>Tên Sách</th>
                <th>Ngày Mượn</th>
                <th>Hạn Trả</th>
                <th>Trạng Thái</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null) {
                foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold">@(item.Student?.FullName ?? "N/A")</td>
                        <td class="text-success fw-bold">@(item.Book?.Title ?? "N/A")</td>
                        <td>@item.BorrowDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if(item.Status == "Borrowing") {
                                <span class="badge bg-warning text-dark">Đang mượn</span>
                            } else {
                                <span class="badge bg-success">Đã trả</span>
                            }
                        </td>
                        <td class="text-center">
                            @if(item.Status == "Borrowing") {
                                <form asp-action="ReturnBook" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-arrow-return-left"></i> Nhận Trả Sách</button>
                                </form>
                            } else {
                                <span class="text-muted"><i class="bi bi-check-circle"></i> Hoàn tất (@item.ReturnDate?.ToString("dd/MM"))</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>