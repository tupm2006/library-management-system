@model SmartLibraryManagementSystem.Data.Entities.Review

@{
    ViewData["Title"] = "Add Review";
}

<h1>Add Review</h1>

<form asp-action="AddReview">
    <div class="form-group">
        <label asp-for="Rating" class="control-label">Rating (1-5)</label>
        <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Comment" class="control-label">Comment</label>
        <textarea asp-for="Comment" class="form-control"></textarea>
        <span asp-validation-for="Comment" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Submit Review" class="btn btn-primary" />
    </div>
</form>