@model IEnumerable<SmartLibraryManagementSystem.Data.Entities.Book>
@{ ViewData["Title"] = "Quản lý Sách"; }

<div class="d-flex justify-content-between align-items-center mb-5 mt-3">
    <div>
        <h1 class="text-primary fw-bold mb-1">Kho Sách Tri Thức</h1>
        <p class="text-muted mb-0 small">Quản lý danh lục sách, số lượng tồn và vị trí kệ IoT.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle me-2"></i> Thêm Sách</a>
</div>

<div class="card shadow-0 border-0" style="background: transparent;">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Mã Sách</th>
                    <th>Tựa Sách</th>
                    <th>Tác Giả</th>
                    <th>Thể Loại</th>
                    <th>Vị Trí (IoT)</th>
                    <th>Trạng Thái</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr class="clickable-card">
                        <td class="fw-bold text-primary">@item.BookCode</td>
                        <td class="fw-bold">@item.Title</td>
                        <td>@item.Author</td>
                        <td><span class="m3-badge btn-tonal px-3 py-1 mb-0" style="font-size: 0.75rem;">@item.Category</span></td>
                        <td><span class="m3-badge bg-primary-container text-primary px-3 py-1 rounded-pill mb-0" style="font-size: 0.75rem;">@item.ShelfCode</span></td>
                        <td>
                            <span class="badge @(item.AvailableQuantity > 0 ? "bg-success" : "bg-danger") rounded-pill px-3 py-1">
                                @item.AvailableQuantity / @item.TotalQuantity
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-tonal py-1 px-3">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger py-1 px-3">Xóa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>